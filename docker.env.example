# Optional overrides for docker compose (place as `.env` beside docker-compose.yml).
# Compose substitutes ${VAR:-default} from this file automatically.
#
# Defaults are already set in docker-compose.yml — you only need this file to
# change secrets or production URLs (similar to gen_cl_dental JWT_SECRET / CORS_ORIGIN).

# JWT_SECRET=your-production-secret-at-least-32-chars
# CLIENT_URL=https://tms.mapims.edu.in
# MONGODB_URI=mongodb://mongo:27017/tms_hospital

# Host ports are fixed in compose (5013 / 8090). Edit docker-compose.yml to change them.
