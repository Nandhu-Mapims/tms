NODE_ENV=development
PORT=5000
# Local MongoDB (no auth). Docker stack sets MONGODB_URI in compose (mongodb://mongo:27017/tms_hospital).
MONGODB_URI=mongodb://127.0.0.1:27017/tms_hospital
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1d
CLIENT_URL=http://localhost:5173
BCRYPT_SALT_ROUNDS=10
# Groq Cloud — https://console.groq.com/keys (OpenAI-compatible API)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
SEED_ADMIN_EMAIL=admin@tmshospital.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=System Administrator
SEED_ADMIN_PHONE=9999999999
