# Backend: local development (npm run dev). Frontend: http://localhost:5173
NODE_ENV=development
PORT=5000

# Local MongoDB without auth on default port:
MONGODB_URI=mongodb://127.0.0.1:27017/tms_hospital
# If Mongo runs in Docker with root/password on host port 27018, use instead:
# MONGODB_URI=mongodb://root:password@127.0.0.1:27018/tms_hospital?authSource=admin

MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

JWT_SECRET=dev-jwt-secret-at-least-32-characters-long-tms
JWT_EXPIRES_IN=1d

# Vite dev server origin (required for CORS)
CLIENT_URL=http://localhost:5173

BCRYPT_SALT_ROUNDS=10

SEED_ADMIN_EMAIL=admin@tmshospital.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=System Administrator
SEED_ADMIN_PHONE=9999999999
